{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PaperExtraction",
  "type": "object",
  "required": [
    "paper_id",
    "filename",
    "title",
    "annotation_setting",
    "scribble_protocol",
    "method_summary",
    "taxonomy_signals",
    "datasets",
    "evidence_spans",
    "extraction_confidence"
  ],
  "properties": {
    "paper_id": {
      "type": "string"
    },
    "filename": {
      "type": "string"
    },
    "bibtex_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "title": {
      "type": "string"
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "year": {
      "type": [
        "integer",
        "null"
      ]
    },
    "venue": {
      "type": [
        "string",
        "null"
      ]
    },
    "method_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "annotation_setting": {
      "type": "string"
    },
    "scribble_protocol": {
      "type": "string"
    },
    "task_domain": {
      "type": "string"
    },
    "modality": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "segmentation_target": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "core_problem": {
      "type": "string"
    },
    "key_contributions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "method_summary": {
      "type": "string"
    },
    "algorithm_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "method_components": {
      "type": "object"
    },
    "taxonomy_signals": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "datasets": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "baselines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "boundary_case_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_spans": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "extraction_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
